{
  "name": "streamer-desktop",
  "version": "1.1.28",
  "main": "dist-electron/main.js",
  "private": true,
  "type": "module",
  "author": "BPCL",
  "description": "BPCL Streamer Hub",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-packager . \"BPCL Streamer Desktop\" --platform=win32 --arch=x64 --out=release --overwrite --electron-version=31.3.1 --ignore=\"^/(src|electron|node_modules|resources|\\.gitignore|vite\\.config|tsconfig)\" && node copy-resources.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "broadcast-api": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "31.3.1",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.bpcl.streamerdesktop",
    "productName": "BPCL Streamer Desktop",
    "win": {
      "target": [
        {
          "target": "dir"
        }
      ],
      "sign": false
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../../apps/broadcast-api",
        "to": "broadcast-api",
        "filter": [
          "src/**",
          "package.json",
          ".env"
        ]
      },
      {
        "from": "../../apps/overlay-web/dist",
        "to": "overlay-web/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../apps/admin-web/dist",
        "to": "admin-web/dist",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
